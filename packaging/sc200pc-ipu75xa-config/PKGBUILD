pkgname=sc200pc-ipu75xa-config
pkgver=2026.04.17
pkgrel=6
pkgdesc="Experimental vendor HAL assets for the Galaxy Book6 Pro SC200PC front camera"
arch=('x86_64')
url="https://github.com/jabbslad/omarchy-extras"
# Intel camera tuning / graph binaries are proprietary. Redistribution
# terms are the same as those governing intel-ipu7-camera's bundled
# IMX471/OV08X40/OV13B10 assets (OEM-provided, unsigned by Intel).
license=('custom:Intel proprietary camera tuning')
depends=('intel-ipu7-camera')
makedepends=()
install="${pkgname}.install"
source=(
  'README.md'
  'sc200pc-uf.json'
  'SC200PC_KAFC917_PTL.aiqb'
  'SC200PC_KAFC917.IPU75XA.bin'
  'sc200pc-hal-check'
)
sha256sums=(
  'SKIP'
  'SKIP'
  'SKIP'
  'SKIP'
  'SKIP'
)

package() {
  install -d "${pkgdir}/etc/camera/ipu75xa/gcss"
  install -d "${pkgdir}/etc/camera/ipu75xa/sensors"
  install -m644 "${srcdir}/sc200pc-uf.json" \
    "${pkgdir}/etc/camera/ipu75xa/sensors/sc200pc-uf.json"

  install -m644 "${srcdir}/SC200PC_KAFC917_PTL.aiqb" \
    "${pkgdir}/etc/camera/ipu75xa/SC200PC_KAFC917_PTL.aiqb"

  install -m644 "${srcdir}/SC200PC_KAFC917.IPU75XA.bin" \
    "${pkgdir}/etc/camera/ipu75xa/gcss/SC200PC_KAFC917.IPU75XA.bin"

  install -Dm755 "${srcdir}/sc200pc-hal-check" \
    "${pkgdir}/usr/bin/sc200pc-hal-check"

  install -Dm644 "${srcdir}/README.md" \
    "${pkgdir}/usr/share/doc/${pkgname}/README.md"
}
