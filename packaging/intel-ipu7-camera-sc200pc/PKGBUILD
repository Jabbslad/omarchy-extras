  'sc200pc-dkms'
  'sc200pc-ipu75xa-config'
)
makedepends=(
  'git'
  'base-devel'
  'cmake'
  'autoconf'
  'automake'
  'libtool'
  'pkgconf'
)
install="${pkgname}.install"
source=(
  "ipu7-camera-bins::git+https://github.com/intel/ipu7-camera-bins.git#commit=403c67db6b279dd02752f11db6a34552f31a3ac5"
  "ipu7-camera-hal::git+https://github.com/intel/ipu7-camera-hal.git#commit=b1f6ebef12111fb5da0133b144d69dd9b001836c"
  "icamerasrc::git+https://github.com/intel/icamerasrc.git#commit=4fb31db76b618aae72184c59314b839dedb42689"
