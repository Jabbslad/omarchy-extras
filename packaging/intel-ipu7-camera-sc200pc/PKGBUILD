license=('GPL-2.0-or-later' 'custom:Intel proprietary camera tuning')
provides=('intel-ipu7-camera')
conflicts=('intel-ipu7-camera')
depends=(
  'v4l2loopback-dkms'
  'v4l2-relayd'
